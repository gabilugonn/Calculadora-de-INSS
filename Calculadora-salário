    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "d5412cbb"
      },
      "source": [
        "# Example usage:\n",
        "gross_salary = 5000.00  # Example gross salary\n",
        "tax_rate = 0.15         # 15% tax rate\n",
        "social_security_rate = 0.10 # 10% social security rate\n",
        "\n",
        "# Calculate net salary\n",
        "net_salary = calculate_net_salary(gross_salary, tax_rate, social_security_rate)\n",
        "\n",
        "print(f\"Gross Salary: R$ {gross_salary:.2f}\")\n",
        "print(f\"Tax Deduction ({(tax_rate*100):.0f}%): R$ {(gross_salary * tax_rate):.2f}\")\n",
        "print(f\"Social Security Deduction ({(social_security_rate*100):.0f}%): R$ {(gross_salary * social_security_rate):.2f}\")\n",
        "print(f\"Net Salary: R$ {net_salary:.2f}\")"
