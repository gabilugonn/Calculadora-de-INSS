      "source": [
        "def calculate_net_salary(gross_salary, tax_rate, social_security_rate):\n",
        "    \"\"\"\n",
        "    Calculates the net salary after deducting tax and social security.\n",
        "\n",
        "    Args:\n",
        "        gross_salary (float): The employee's gross salary.\n",
        "        tax_rate (float): The tax rate as a decimal (e.g., 0.15 for 15%).\n",
        "        social_security_rate (float): The social security rate as a decimal (e.g., 0.10 for 10%).\n",
        "\n",
        "    Returns:\n",
        "        float: The net salary.\n",
        "    \"\"\"\n",
        "    tax_deduction = gross_salary * tax_rate\n",
        "    social_security_deduction = gross_salary * social_security_rate\n",
        "    net_salary = gross_salary - tax_deduction - social_security_deduction\n",
        "    return net_salary"
      ],
      "execution_count": null,
      "outputs": []
    },
